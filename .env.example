YUNO_HOST=127.0.0.1
YUNO_PORT=8080
YUNO_LLM_PROVIDER=local

# Optional: use OpenAI for model output. Local mode is deterministic and works without keys.
# YUNO_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# YUNO_OPENAI_MODEL=gpt-4.1-mini

# Optional: enable live Telegram bot polling.
# Create a bot with @BotFather, paste the token, and set ENABLE_TELEGRAM=true.
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WORKFLOW_ID=workflow-support
